{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@shared/*": [
        "cloudfunctions/shared/*"
      ]
    },
    "types": [
      "node",
      "miniprogram-api-typings"
    ]
  },
  "include": [
    "src",
    "config",
    "cloudfunctions/shared"
  ]
}
